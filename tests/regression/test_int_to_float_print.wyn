// EXPECT: 5.0
// EXPECT: 5.0
// EXPECT: 5.0
// EXPECT: 3.5
// EXPECT: 6.0
// Regression: print(x.to_float()) where x is int segfaulted - the print arg's
// receiver-type override rerouted to_float on a checker-typed INT through
// str_parse_float (int passed as const char*). The override now only fires
// when the object is NOT typed as a number/bool, so string .to_float still
// parses. (codegen type-selection drive, 2026-07)
fn main() -> int {
    var x = 5
    print(x.to_float())
    println(x.to_float())
    var f = x.to_float()
    println(f)
    var s = "3.5"
    println(s.to_float())
    println(x.to_float() + 1.0)
    return 0
}
