// EXPECT: P { x: 1, y: 2 }
// EXPECT: U { name: "ada", age: 36, score: 9.5, ok: true }
// EXPECT: Some(7)
// EXPECT: none
// EXPECT: 99
// EXPECT: ["a7", "b7"]
// println on rich types - every case here used to be an internal codegen
// error on completely valid code:
// - println(struct): to_string(p) passed a struct to a long long param
// - println(option): same for OptionInt/OptionString values
// - m[0][1] = v: took the address of an rvalue
// - "${n}" inside a lambda: the captured var was never collected/declared

struct P { x: int, y: int }
struct U { name: string, age: int, score: float, ok: bool }

fn find() -> int? { return Some(7) }
fn miss() -> string? { return None }

fn main() -> int {
    p = P { x: 1, y: 2 }
    println(p)

    u = U { name: "ada", age: 36, score: 9.5, ok: true }
    println(u)

    x = find()
    println(x)

    y = miss()
    println(y)

    m = [[1, 2], [3, 4]]
    m[0][1] = 99
    println(m[0][1].to_string())

    n = 7
    a = ["a", "b"]
    b = a.map((s) => "${s}${n}")
    println(b)
    return 0
}
