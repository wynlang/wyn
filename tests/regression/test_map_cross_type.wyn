// EXPECT: [0.5, 1.5]
// EXPECT: [2.5, 7.5]
// EXPECT: [1, 2]
// Regression: cross-type array maps silently disagreed with the lambda's ABI.
// [int].map((n) => n.to_float()) rode wyn_array_map (long long ABI) and read
// the double return as an integer bit pattern; [float].map((f) => f.to_int())
// likewise in reverse. The emitter now picks the variant from BOTH the element
// type (param ABI) and the checker's lambda return type (result ABI):
// wyn_array_map_int_to_float / wyn_array_map_float_to_int.
fn main() -> int {
    var xs = [1, 3]
    var halves = xs.map((n) => n.to_float() / 2.0)
    println(halves)
    var doubled = xs.map((n) => n * 2.5)
    println(doubled)
    var fs = [1.9, 2.9]
    var ints = fs.map((f) => f.to_int())
    println(ints)
    return 0
}
