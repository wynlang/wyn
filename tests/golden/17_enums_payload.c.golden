#include "wyn_runtime.h"
#ifdef __TINYC__
#define __auto_type long long
#endif

typedef struct {
    enum { Shape_Circle_TAG, Shape_Rect_TAG } tag;
    union {
        int Circle_value;
        struct { int f0; int f1; } Rect_value;
    } data;
} Shape;


Shape Shape_Circle(int value) {
    Shape result;
    result.tag = Shape_Circle_TAG;
    result.data.Circle_value = value;
    return result;
}

Shape Shape_Rect(int f0, int f1) {
    Shape result;
    result.tag = Shape_Rect_TAG;
    result.data.Rect_value.f0 = f0;
    result.data.Rect_value.f1 = f1;
    return result;
}

const char* Shape_toString(Shape val) {
    switch(val.tag) {
        case Shape_Circle_TAG: return "Circle";
        case Shape_Rect_TAG: return "Rect";
    }
    return "Unknown";
}


// Lambda functions (defined before use)
__attribute__((hot)) static inline long long area(Shape s);
long long wyn_main();

