// Wyn Spawn Benchmark — measures M:N scheduler performance

fn tiny(x: int) -> int { return x }
fn add(a: int, b: int) -> int { return a + b }

fn compute(n: int) -> int {
    var sum = 0
    for i in 0..n { sum = sum + i }
    return sum
}

fn increment(counter: int) -> int {
    Shared.add(counter, 1)
    return 0
}

fn main() -> int {
    // Warmup scheduler
    var w = spawn tiny(0)
    await w
    sleep_ms(10)

    println("╔══════════════════════════════════════════════════════╗")
    println("║         Wyn Spawn Benchmark (M:N Scheduler)         ║")
    println("╚══════════════════════════════════════════════════════╝")
    println("")

    // === Test 1: Sequential spawn+await (5K) ===
    var t0 = DateTime.micros()
    for i in 0..5000 {
        var f = spawn tiny(i)
        await f
    }
    var t1 = DateTime.micros()
    var seq_us = (t1 - t0) / 5000
    println("  Sequential spawn+await (5K ops):   ${seq_us} us/op")

    // === Test 2: Concurrent batch with await_all ===
    var t2 = DateTime.micros()
    var futures = []
    for i in 0..100 {
        futures.push(spawn tiny(i))
    }
    var batch_results = await_all(futures)
    var t3 = DateTime.micros()
    var batch_us = (t3 - t2) / 100
    println("  Concurrent batch (100 + await_all): ${batch_us} us/op")

    // === Test 3: Correctness ===
    var fa = spawn add(100, 200)
    var fb = spawn add(300, 400)
    var ra = await fa
    var rb = await fb
    var correct = "PASS"
    if ra != 300 { correct = "FAIL" }
    if rb != 700 { correct = "FAIL" }
    println("  Correctness:                       ${correct}")

    // === Test 4: Shared atomic counter ===
    var counter = Shared.new(0)
    var inc_futures = []
    for i in 0..100 {
        inc_futures.push(spawn increment(counter))
    }
    await_all(inc_futures)
    var shared_correct = "PASS"
    if Shared.get(counter) != 100 { shared_correct = "FAIL" }
    println("  Shared atomic (100 workers):       ${shared_correct}")

    // === Test 5: Parallel speedup ===
    var n = 20000000
    var t4 = DateTime.micros()
    compute(n)
    compute(n)
    compute(n)
    compute(n)
    var t5 = DateTime.micros()

    var t6 = DateTime.micros()
    var c1 = spawn compute(n)
    var c2 = spawn compute(n)
    var c3 = spawn compute(n)
    var c4 = spawn compute(n)
    await c1
    await c2
    await c3
    await c4
    var t7 = DateTime.micros()

    var seq_ms = (t5 - t4) / 1000
    var par_ms = (t7 - t6) / 1000
    var speedup = "N/A"
    if par_ms > 0 { speedup = (seq_ms * 10 / par_ms).to_string() + "/10x" }
    println("  Sequential 4x compute(20M):        ${seq_ms} ms")
    println("  Parallel   4x compute(20M):        ${par_ms} ms")
    println("  Speedup:                           ${speedup}")

    println("")
    println("  ┌─────────────────────────────────────────────────┐")
    println("  │ Stack: 8MB virtual per spawn (~4-8KB RSS)       │")
    println("  │ Concurrent limit: ~5-10K (8MB × N virtual)      │")
    println("  │ Throughput: 10K+/s via batched await_all         │")
    println("  │ Architecture: M:N with work-stealing deques      │")
    println("  └─────────────────────────────────────────────────┘")
    println("")

    // === Assertions ===
    Test.init("Spawn Benchmark Assertions")
    Test.assert(seq_us < 100, "sequential overhead < 100us")
    Test.assert(batch_us < 100, "batch overhead < 100us")
    Test.assert_eq_int(ra, 300, "add(100,200) = 300")
    Test.assert_eq_int(rb, 700, "add(300,400) = 700")
    Test.assert_eq_int(Shared.get(counter), 100, "100 workers = 100")
    Test.summary()

    return 0
}
