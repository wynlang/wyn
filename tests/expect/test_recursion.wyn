// EXPECT: 120
// EXPECT: 1
// EXPECT: 55

fn factorial(n: int) -> int {
    if n <= 1 { return 1 }
    return n * factorial(n - 1)
}

fn fib(n: int) -> int {
    if n <= 1 { return n }
    return fib(n - 1) + fib(n - 2)
}

fn main() -> int {
    println(factorial(5).to_string())
    println(factorial(1).to_string())
    println(fib(10).to_string())
    return 0
}
