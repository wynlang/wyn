// Language features: for-in iteration, pipe operator

fn double_val(x: int) -> int { return x * 2 }
fn add1(x: int) -> int { return x + 1 }

fn main() -> int {
    Test.init("Language Features")

    // For-in array iteration
    var names = ["alice", "bob", "charlie"]
    var count = 0
    for name in names {
        count += 1
    }
    Test.assert_eq_int(count, 3, "for-in count")

    // Pipe with named functions
    var r1 = 5 |> double_val |> add1
    Test.assert_eq_int(r1, 11, "pipe chain")

    var r2 = 3 |> add1 |> double_val |> add1
    Test.assert_eq_int(r2, 9, "pipe 3-stage")

    Test.summary()
    return 0
}
