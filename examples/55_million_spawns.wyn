// Spawn Scaling — demonstrates spawn throughput via batching
// With 8MB default stacks, ~5-10K concurrent spawns are practical.
// Higher throughput achieved by batching: spawn, await, recycle.

fn worker(id: int) -> int {
    return id + 1
}

fn main() -> int {
    println("=== Spawn Scaling ===")
    println("")

    // Batch 10 × 1K = 10K total spawns with recycling
    var total = 0
    for batch in 0..10 {
        var futures = []
        for i in 0..1000 {
            futures.push(spawn worker(batch * 1000 + i))
        }
        var results = await_all(futures)
        for i in 0..1000 {
            total = total + results[i]
        }
    }

    // sum of (i+1) for i=0..9999 = 50005000
    println("  10K spawns (10 × 1K batches): total = ${total}")
    if total == 50005000 {
        println("  ✓ Correct!")
    }

    println("")
    println("  Note: ~5-10K concurrent spawns with 8MB stacks.")
    println("  Higher throughput via batching (spawn, await_all, recycle).")
    println("")
    return 0
}
