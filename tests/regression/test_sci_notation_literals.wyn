// Scientific-notation float literals (HN crucible P1-3): 1.0e10, 1e-6, 2E+8
// did not lex even though Wyn PRINTS floats in that form - its own output
// could not be read back. The 'e' is only consumed when a valid exponent
// follows, so identifiers after a number (5.elements-style) still lex.
// EXPECT: 10000000000.0
// EXPECT: 1e-06
// EXPECT: 200000000.0
// EXPECT: 1500.0
// EXPECT: 20000000000.0

fn main() {
    print(1.0e10)
    print(1e-6)
    print(2E+8)
    print(1.5e3)
    a = 1.0e10
    print(a * 2.0)
}
