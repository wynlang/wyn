// main.wyn - Uses the utils module
import utils

fn main() {
    // Whole-module `import utils` requires the qualified `utils.foo()` form.
    var result1 = utils.double(5)
    var result2 = utils.triple(4)
    var max = MAX_SIZE           // Can access exported variables

    result1.print()  // 10
    result2.print()  // 12
    max.print()      // 100

    // This would NOT work - private_helper is not exported:
    // var result3 = private_helper(3)  // ERROR: Undefined function
}
