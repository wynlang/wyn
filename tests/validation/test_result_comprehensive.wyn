// Result type comprehensive tests — standalone (not test blocks)
// TCC can't handle ResultInt structs in test blocks, so we test via assertions in main

fn safe_div(a: int, b: int) -> Result<int, string> {
    if b == 0 { return Err("division by zero") }
    return Ok(a / b)
}

fn parse_int(s: string) -> Result<int, string> {
    if s == "0" { return Ok(0) }
    var n = s.to_int()
    if n == 0 { return Err("not a number: " + s) }
    return Ok(n)
}

fn main() -> int {
    var pass = 0
    var fail = 0

    // Test 1: Ok unwrap
    var r1 = safe_div(10, 2)
    if r1.is_ok() && r1.unwrap() == 5 { pass += 1 } else { fail += 1; println("FAIL: Ok unwrap") }

    // Test 2: Err detection
    var r2 = safe_div(10, 0)
    if r2.is_err() { pass += 1 } else { fail += 1; println("FAIL: Err detection") }

    // Test 3: unwrap_or
    var r3 = safe_div(10, 0)
    if r3.unwrap_or(99) == 99 { pass += 1 } else { fail += 1; println("FAIL: unwrap_or") }

    // Test 4: Ok match
    var r4 = safe_div(20, 4)
    var v4 = 0
    match r4 {
        Ok(v) => { v4 = v },
        Err(e) => { v4 = -1 }
    }
    if v4 == 5 { pass += 1 } else { fail += 1; println("FAIL: Ok match, got ${v4}") }

    // Test 5: Err match
    var r5 = safe_div(20, 0)
    var got_err = 0
    match r5 {
        Ok(v) => { got_err = 0 },
        Err(e) => { got_err = 1 }
    }
    if got_err == 1 { pass += 1 } else { fail += 1; println("FAIL: Err match") }

    // Test 6: Multiple Results
    var r6a = safe_div(100, 10)
    var r6b = safe_div(100, 0)
    if r6a.is_ok() && r6b.is_err() { pass += 1 } else { fail += 1; println("FAIL: Multiple Results") }

    // Test 7: Result from different function
    var r7 = parse_int("42")
    if r7.is_ok() && r7.unwrap() == 42 { pass += 1 } else { fail += 1; println("FAIL: parse_int Ok") }

    // Test 8: Result error from different function
    var r8 = parse_int("abc")
    if r8.is_err() { pass += 1 } else { fail += 1; println("FAIL: parse_int Err") }

    println("Result tests: ${pass} pass, ${fail} fail")
    if fail > 0 { return 1 }
    return 0
}
