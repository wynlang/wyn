# Compiler binary
wyn
wyn-llvm
wyn-windows.exe
wyn-linux
wyn-macos

# Generated files from compilation
*.out
*.o
*.wyn.out
*.wyn.c
*.dSYM/

# Build directories
build/
temp/
.dev-scripts/

# Test executables (but not test source files)
tests/test_lexer
tests/test_parser
tests/test_checker
tests/test_codegen
!tests/*.c
!tests/*.h

# IDE
.vscode/
.idea/
*.swp
*.swo

# Logs and backups
*.log
*_backup.*
*.bak
*.bak[0-9]
*.backup
*.orig

# OS
.DS_Store

# Runtime build artifacts
runtime/libwyn_rt.a
runtime/obj/
wyn_cc_err.txt
runtime/libwyn_runtime.a
wyn_runtime.h.gch
# Precompiled header (regenerated; not linked or referenced by the build)
runtime/wyn_runtime.h.pch
*.pch

# Database files
*.db

# Test binaries (compiled from .wyn)
tests/concurrency/test_*
!tests/concurrency/test_*.wyn
tests/memory/test_*
!tests/memory/test_*.wyn
tests/validation/test_*
!tests/validation/test_*.wyn
tests/stdlib/test_*
!tests/stdlib/test_*.wyn
tests/test_*
!tests/test_*.wyn
!tests/test_*.c
# Compiled test-runner binary (source is run_tests.sh / .wyn, not this binary)
tests/run_tests
!tests/run_tests.sh
!tests/run_tests*.sh
runtime/libwyn_rt_asan.a
runtime/obj_asan/
runtime/libwyn_rt_tsan.a
runtime/obj_tsan/
# compiled expect-test binaries (no extension)
tests/expect/*
!tests/expect/*.wyn
!tests/expect/*.sh
