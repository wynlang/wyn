// Regression: `wyn fmt` used to CORRUPT valid code - it inserted a space into the
// inclusive-range operator (`0..=10` -> `0.. = 10`) because the lone-'=' spacing
// rule fired after the '.', and into slice syntax (`xs[1:3]` -> `xs[1: 3]`) because
// the ':' annotation-spacing rule fired inside `[ ]`. Both broke re-parsing.
// This file is already in canonical formatted form; `wyn fmt --check` must pass
// (the test harness in tests/ is fmt-clean), and it must run correctly, proving the
// formatter leaves `..=` and `[a:b]` intact.
// EXPECT: 15
// EXPECT: [2, 3]
// EXPECT: [1, 2]
// EXPECT: [3, 4, 5]
// EXPECT: 3
fn main() {
    var total = 0
    for i in 1..=5 { total = total + i }   // inclusive range must survive fmt
    println(total)                          // 15

    var xs = [1, 2, 3, 4, 5]
    println(xs[1:3])                        // [2, 3]   slice must survive fmt
    println(xs[:2])                         // [1, 2]
    println(xs[2:])                         // [3, 4, 5]

    var m = { "a": 1, "b": 2 }              // annotation-style ':' still spaced fine
    println(m["a"] + m["b"])                // 3
}
