// Pythonic negative indexing (a[-1] == last) and open-ended slices
// (a[:n], a[n:], a[:]). Negative indices were a runtime panic; open-ended
// slices were a codegen error.
// EXPECT: PASS: negative index and slices

fn main() -> int {
    var a = [10, 20, 30, 40]
    if a[-1] != 40 { println("FAIL: a[-1]"); return 1 }
    if a[-2] != 30 { println("FAIL: a[-2]"); return 1 }
    if a[-4] != 10 { println("FAIL: a[-4]"); return 1 }

    var s = ["x", "y", "z"]
    if s[-1] != "z" { println("FAIL: str a[-1]"); return 1 }

    // open-ended slices
    if a[:2].len() != 2 { println("FAIL: a[:2]"); return 1 }
    if a[2:].len() != 2 { println("FAIL: a[2:]"); return 1 }
    if a[:].len() != 4 { println("FAIL: a[:]"); return 1 }
    if a[1:3].len() != 2 { println("FAIL: a[1:3]"); return 1 }

    // slice then index, and negative index into a slice
    var tail = a[2:]
    if tail[0] != 30 { println("FAIL: a[2:][0]"); return 1 }
    if tail[-1] != 40 { println("FAIL: a[2:][-1]"); return 1 }

    println("PASS: negative index and slices")
    return 0
}
