// EXPECT: len=805
// EXPECT: ok=true
// Interpolation result exceeds the old fixed char[512] buffer. Previously
// truncated to 511 bytes; now size-probed + heap-allocated, so it round-trips.
fn main() -> int {
    var big = ""
    var s = "[${big}]<<<"
    println("len=${s.len()}")
    var expected_tail = "]<<<"
    println("ok=${s.contains(expected_tail)}")
    return 0
}
