    return 1;
}
static int __wyn_eq_User(User __l, User __r) {
    if (strcmp(__l.name ? __l.name : "", __r.name ? __r.name : "") != 0) return 0;
    if (!__wyn_eq_Addr(__l.addr, __r.addr)) return 0;
