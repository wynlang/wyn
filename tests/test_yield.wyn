// Test L3: yield and lazy iterators

// Generator: produces values 0..n lazily
fn range_gen(n: int) -> iter {
    for i in 0..n {
        yield i
    }
}

// Generator: produces fibonacci numbers
fn fib_gen(count: int) -> iter {
    var a = 0
    var b = 1
    for i in 0..count {
        yield a
        var tmp = a + b
        a = b
        b = tmp
    }
}

// Generator: infinite counter (take first N)
fn counter() -> iter {
    var i = 0
    while true {
        yield i
        i = i + 1
    }
}

fn double(x: int) -> int { return x * 2 }
fn is_even(x: int) -> bool { return x % 2 == 0 }

fn main() -> int {
    // Basic generator
    var nums = range_gen(5)
    var collected = nums.collect()
    assert_eq(collected.len(), 5)
    assert_eq(collected[0], 0)
    assert_eq(collected[4], 4)
    println("range_gen: pass")

    // Fibonacci generator
    var fibs = fib_gen(7).collect()
    assert_eq(fibs[0], 0)
    assert_eq(fibs[1], 1)
    assert_eq(fibs[6], 8)
    println("fib_gen: pass")

    // Lazy: take from infinite generator
    var first5 = counter().take(5).collect()
    assert_eq(first5.len(), 5)
    assert_eq(first5[4], 4)
    println("take: pass")

    // Chain: generator + map
    var doubled = range_gen(4).map(double).collect()
    assert_eq(doubled[0], 0)
    assert_eq(doubled[1], 2)
    assert_eq(doubled[3], 6)
    println("map: pass")

    // Chain: generator + filter
    var evens = range_gen(10).filter(is_even).collect()
    assert_eq(evens[0], 0)
    assert_eq(evens[1], 2)
    assert_eq(evens[2], 4)
    println("filter: pass")

    // Chain: filter + map + take
    var result = counter().filter(is_even).map(double).take(3).collect()
    assert_eq(result[0], 0)
    assert_eq(result[1], 4)
    assert_eq(result[2], 8)
    println("chain: pass")

    // for-in over generator
    var sum = 0
    for x in range_gen(5) {
        sum = sum + x
    }
    assert_eq(sum, 10)
    println("for-in: pass")

    println("L3: 7 tests passed")
    return 0
}
