// Regression: HashMap value access — both m[k] and m.get(k) — must select the
// getter/type matching the map's VALUE type, not always hashmap_get_string.
// Before, int/float/bool maps returned garbage/empty (broke shipped
// examples/06_hashmap.wyn — "Alice's age:" blank) and `if m.get(k) != N`
// segfaulted (strcmp on an int). The type flows from the {k:v} literal through
// index/get/comparison/var-decl. HashMap.new() maps (no inferred value type)
// keep the historical string default.
// EXPECT: PASS: hashmap value types

fn main() -> int {
    var ages = { "alice": 30, "bob": 25 }
    if ages["alice"] != 30 { println("FAIL: int index inline"); return 1 }
    var ai = ages["alice"]
    if ai != 30 { println("FAIL: int index var"); return 1 }
    if ages.get("bob") != 25 { println("FAIL: int get inline"); return 1 }
    var ag = ages.get("bob")
    if ag != 25 { println("FAIL: int get var"); return 1 }

    var names = { "a": "apple", "b": "banana" }
    if names["a"] != "apple" { println("FAIL: string index"); return 1 }
    if names.get("b") != "banana" { println("FAIL: string get"); return 1 }

    var prices = { "x": 1.5 }
    var px = prices["x"]
    if px < 1.4 { println("FAIL: float index"); return 1 }

    var flags = { "on": true, "off": false }
    if flags["on"] != true { println("FAIL: bool index"); return 1 }

    println("PASS: hashmap value types")
    return 0
}
