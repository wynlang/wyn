// Wyn Test Runner — parallel via spawn/await (batched)

fn run_test(path: string) -> int {
    var cmd = "./wyn run " + path + " 2>&1; echo EXIT:$?"
    var output = System_exec(cmd)
    if !output.contains("EXIT:0") { return 0 }
    if output.contains("Segmentation fault") { return 0 }
    return 1
}

fn main() -> int {
    var start = DateTime_millis()
    println("=== Wyn Test Runner ===")
    var tests: [string] = []
    var lines = read_file_content("tests/test_list.txt")
    // Parse test list — one path per line
    var current = ""
    for i in 0..lines.len() {
        var ch = lines.char_at(i)
        if ch == "\n" {
            if current.len() > 0 { tests.push(current) }
            current = ""
        } else {
            current = current + ch
        }
    }
    if current.len() > 0 { tests.push(current) }

    var count = tests.len()
    var pass = 0
    var fail = 0
    var batch = 12

    var i = 0
    while i < count {
        // Spawn a batch
        var futures: [int] = []
        var batch_end = i + batch
        if batch_end > count { batch_end = count }
        var j = i
        while j < batch_end {
            var f = spawn run_test(tests[j])
            futures.push(f)
            j = j + 1
        }
        // Await batch
        j = 0
        while j < futures.len() {
            var result = await futures[j]
            if result == 1 { pass = pass + 1 }
            else { fail = fail + 1; println("  FAIL: " + tests[i + j]) }
            j = j + 1
        }
        i = batch_end
    }

    var elapsed = DateTime_millis() - start
    println("")
    println("Results: " + pass.to_string() + " pass, " + fail.to_string() + " fail (" + elapsed.to_string() + "ms)")
    return fail
}
