// Regression: a broad smoke test mirroring the "Learn Wyn in Y Minutes" tour -
// exercises functions, expr-body fns, default args, braceless control flow,
// slices, negative index, HOF, zip, structs+methods, enums+match, optionals + ?.,
// generics, closures + closure-copy, and spawn/await/await_all/parallel together.
// Deterministic output only (no fire-and-forget ordering).
// EXPECT: 5
// EXPECT: 36
// EXPECT: hello, world
// EXPECT: big
// EXPECT: 15
// EXPECT: 5
// EXPECT: [2, 3]
// EXPECT: [6, 8, 10]
// EXPECT: 25
// EXPECT: 12
// EXPECT: 3
// EXPECT: -1
// EXPECT: 105
// EXPECT: 81
// EXPECT: 14
// EXPECT: 25
fn add(a: int, b: int) -> int { return a + b }
fn square(n: int) -> int => n * n
fn greet(who: string = "world") -> string { return "hello, ${who}" }
struct Point { x: int, y: int }
impl Point { fn dist2(self) -> int { return self.x * self.x + self.y * self.y } }
enum Shape { Circle(int), Rect(int, int) }
fn area(s: Shape) -> int { return match s { Circle(r) => r * r * 3, Rect(w, h) => w * h } }
fn find(id: int) -> Point? { if id == 1 { return Some(Point { x: 3, y: 4 }) } return None }
fn identity<T>(x: T) -> T { return x }

fn main() {
    println(add(2, 3))                      // 5
    println(square(6))                      // 36
    println(greet())                        // hello, world

    var count = 11
    if count > 10 { println("big") } else { println("small") }

    var total = 0
    for i in 1..=5 { total = total + i }
    println(total)                          // 15

    var xs = [1, 2, 3, 4, 5]
    println(xs[-1])                         // 5
    println(xs[1:3])                        // [2, 3]
    println(xs.map(|n| n * 2).filter(|n| n > 4))  // [6, 8, 10]

    var p = Point { x: 3, y: 4 }
    println(p.dist2())                      // 25
    println(area(Shape.Circle(2)))          // 12

    println((find(1)?.x).unwrap_or(-1))     // 3
    println((find(2)?.x).unwrap_or(-1))     // -1

    var base = 100
    var f = |n| n + base
    var g = f
    println(g(5))                           // 105

    var fut = spawn square(9)
    println(await fut)                      // 81
    var futs = []
    for i in 1..4 { futs.push(spawn square(i)) }
    var rs = await_all(futs)
    var acc = 0
    for _, r in rs { acc = acc + r }
    println(acc)                            // 14
    parallel {
        a = spawn square(3)
        b = spawn square(4)
    }
    println(a + b)                          // 25
}
