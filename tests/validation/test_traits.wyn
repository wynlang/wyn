// TDD: traits and trait bounds

trait Describable {
    fn describe(self) -> string
}

trait HasArea {
    fn area(self) -> int
}

struct Circle {
    radius: int
}

struct Rect {
    width: int
    height: int
}

impl Describable for Circle {
    fn describe(self) -> string {
        return "circle(r=" + self.radius.to_string() + ")"
    }
}

impl Describable for Rect {
    fn describe(self) -> string {
        return "rect(" + self.width.to_string() + "x" + self.height.to_string() + ")"
    }
}

impl HasArea for Rect {
    fn area(self) -> int {
        return self.width * self.height
    }
}

// Trait-bounded function parameter
fn show(item: Describable) -> string {
    return item.describe()
}

fn main() {
    Test.init("Traits and Bounds")

    var c = Circle { radius: 5 }
    var r = Rect { width: 3, height: 4 }

    // Direct method calls
    Test.assert_eq_str(c.describe(), "circle(r=5)", "circle describe")
    Test.assert_eq_str(r.describe(), "rect(3x4)", "rect describe")
    Test.assert_eq_int(r.area(), 12, "rect area")

    // Trait dispatch
    Test.assert_eq_str(show(c), "circle(r=5)", "dispatch circle")
    Test.assert_eq_str(show(r), "rect(3x4)", "dispatch rect")

    Test.summary()
}
