// TDD: method chaining — everything is an object

fn main() {
    Test.init("Method Chaining")

    // Array chaining: sort + reverse
    var nums = [3, 1, 4, 1, 5, 9, 2, 6]
    var desc = nums.sort().reverse()
    Test.assert_eq_int(desc[0], 9, "sort().reverse() first")
    Test.assert_eq_int(desc[1], 6, "sort().reverse() second")

    // Array chaining: filter + sort
    var evens = [4, 2, 8, 6, 1, 3].filter(fn(x: int) -> bool { return x % 2 == 0 }).sort()
    Test.assert_eq_int(evens[0], 2, "filter().sort() first")
    Test.assert_eq_int(evens[3], 8, "filter().sort() last")

    // Array: sort + len
    var count = [5, 3, 1].sort().len()
    Test.assert_eq_int(count, 3, "sort().len()")

    // Array: sort + reverse + len
    var n = [1, 2, 3].sort().reverse().len()
    Test.assert_eq_int(n, 3, "sort().reverse().len()")

    // String chaining: upper + replace
    var s = "hello world".upper().replace("WORLD", "WYN")
    Test.assert_eq_str(s, "HELLO WYN", "upper().replace()")

    // String chaining: lower + trim
    var s2 = "  HELLO  ".trim().lower()
    Test.assert_eq_str(s2, "hello", "trim().lower()")

    // String: split + join
    var s3 = "a,b,c".split(",").join("-")
    Test.assert_eq_str(s3, "a-b-c", "split().join()")

    // String: split + len
    var n2 = "one two three".split(" ").len()
    Test.assert_eq_int(n2, 3, "split().len()")

    // Int methods
    Test.assert_eq_str(42.to_string(), "42", "int.to_string()")
    Test.assert_eq_int((-5).abs(), 5, "int.abs()")

    // Pipe operator
    Test.assert_eq_str(true.to_string(), "true", "bool.to_string()")

    Test.summary()
}
