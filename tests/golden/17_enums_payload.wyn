// Golden: enum with payload variants + match extraction.
enum Shape {
    Circle(int),
    Rect(int, int)
}

fn area(s: Shape) -> int {
    return match s {
        Circle(r) => r * r * 3,
        Rect(w, h) => w * h
    }
}

fn main() {
    println(area(Shape.Circle(2)))
    println(area(Shape.Rect(3, 4)))
}
