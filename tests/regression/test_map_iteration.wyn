// Pythonic map iteration: `for k, v in m` binds key (string) + value (typed by
// the map's value type); `for k in m` iterates keys. Was an internal codegen
// error. Uses order-independent aggregates since map order isn't guaranteed.
// EXPECT: PASS: map iteration

fn main() -> int {
    var m = {"a": 1, "b": 2, "c": 3}

    // for k, v - sum values, concat keys length
    var vsum = 0
    var kcount = 0
    for k, v in m {
        vsum = vsum + v
        if k in m { kcount = kcount + 1 }   // every key must be present
    }
    if vsum != 6 { println("FAIL: value sum"); return 1 }
    if kcount != 3 { println("FAIL: key count"); return 1 }

    // for k (single var) - keys
    var n = 0
    for k in m { n = n + 1 }
    if n != 3 { println("FAIL: keys iteration"); return 1 }

    // string-valued map
    var sm = {"x": "one", "y": "two"}
    var joined = 0
    for k, v in sm {
        if v == "one" or v == "two" { joined = joined + 1 }
    }
    if joined != 2 { println("FAIL: string values"); return 1 }

    println("PASS: map iteration")
    return 0
}
