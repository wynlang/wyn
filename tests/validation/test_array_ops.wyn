// Stress test: arrays with various operations

fn main() {
    Test.init("Array Operations")

    // 1: array creation and access
    var a = [10, 20, 30, 40, 50]
    Test.assert_eq_int(a[0], 10, "arr[0]")
    Test.assert_eq_int(a[4], 50, "arr[4]")
    Test.assert_eq_int(a.len(), 5, "arr len")

    // 2: push and pop
    var b = [1, 2, 3]
    b.push(4)
    Test.assert_eq_int(b.len(), 4, "push len")
    Test.assert_eq_int(b[3], 4, "push val")

    // 3: map
    var c = [1, 2, 3, 4]
    var doubled = c.map(fn(x: int) -> int { return x * 2 })
    Test.assert_eq_int(doubled[0], 2, "map[0]")
    Test.assert_eq_int(doubled[3], 8, "map[3]")

    // 4: filter
    var d = [1, 2, 3, 4, 5, 6]
    var evens = d.filter(fn(x: int) -> int { return x % 2 == 0 })
    Test.assert_eq_int(evens.len(), 3, "filter len")
    Test.assert_eq_int(evens[0], 2, "filter[0]")

    // 5: sort
    var unsorted = [5, 3, 1, 4, 2]
    var sorted = unsorted.sort()
    Test.assert_eq_int(sorted[0], 1, "sort[0]")
    Test.assert_eq_int(sorted[4], 5, "sort[4]")

    // 6: for..in with sum
    var nums = [10, 20, 30]
    var sum = 0
    for n in nums { sum = sum + n }
    Test.assert_eq_int(sum, 60, "for..in sum")

    // 7: array of strings
    var names = ["alice", "bob"]
    Test.assert_eq_str(names[0], "alice", "str arr[0]")
    Test.assert_eq_str(names[1], "bob", "str arr[1]")

    // 8: nested array access
    var matrix = [[1, 2], [3, 4]]
    Test.assert_eq_int(matrix[0][0], 1, "matrix[0][0]")
    Test.assert_eq_int(matrix[1][1], 4, "matrix[1][1]")

    Test.summary()
}
