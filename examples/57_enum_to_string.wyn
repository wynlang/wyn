// Enum to_string() - v1.11 feature
// Enums now have a .to_string() method that returns the variant name.

enum Color { Red, Green, Blue }
enum Direction { North, South, East, West }

fn main() -> int {
    print(Color.Red.to_string())
    print(Color.Green.to_string())
    print(Color.Blue.to_string())

    var d = Direction.West
    print(d.to_string())

    return 0
}
