// EXPECT: 15
// EXPECT: 101
// EXPECT: 25
// EXPECT: 30
// Closure environments are RC-allocated and released when a non-escaping
// closure local leaves scope (fixes an unbounded leak - a loop creating N
// closures used to grow RSS linearly). Returned closures MOVE their env to the
// caller (not freed early), so add5/add100 stay valid after make_adder returns,
// and a fresh closure created each loop iteration is reclaimed per-iteration.
fn make_adder(n: int) -> fn(int) -> int {
    return (x) => x + n
}
fn main() -> int {
    var add5 = make_adder(5)
    var add100 = make_adder(100)
    println("${add5(10)}")     // 15  - returned closure still valid
    println("${add100(1)}")    // 101 - second live closure, distinct env
    println("${add5(20)}")     // 25  - first closure still valid after the second

    // Non-escaping closure created and used inside a loop body: its env is
    // released each iteration (no leak). Sum stays correct.
    var total = 0
    var i = 0
    while i < 5 {
        var f = make_adder(i)
        total = total + f(1)   // (0+1)+(1+1)+(2+1)+(3+1)+(4+1) = 1+2+3+4+5 = 15... plus...
        i = i + 1
    }
    println("${total + 15}")   // 15 (loop) + 15 = 30
    return 0
}
