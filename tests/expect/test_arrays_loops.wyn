// EXPECT: 15
// EXPECT: 5
// EXPECT: hello world

fn main() -> int {
    var nums = [1, 2, 3, 4, 5]
    var total = 0
    for n in nums {
        total = total + n
    }
    println(total.to_string())
    println(nums.len().to_string())

    var words = ["hello", "world"]
    println(words[0] + " " + words[1])
    return 0
}
