typedef struct {
    long long x;
    long long y;
} Point;

void Point_cleanup(Point* obj) {
}

static int __wyn_eq_Point(Point __l, Point __r);
static int __wyn_eq_Point(Point __l, Point __r) {
    if (__l.x != __r.x) return 0;
    if (__l.y != __r.y) return 0;
    return 1;
}

// Lambda functions (defined before use)
long long Point_dist2(Point self) {
    return ((self.x * self.x) + (self.y * self.y));
}

